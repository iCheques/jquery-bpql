{
  "name": "jquery-bpql",
  "version": "2.0.0",
  "description": "Tiny jQuery 4 plugin for talking to BPQL, the SQL-flavored query language created by BIPBOP.",
  "type": "module",
  "main": "dist/jquery-bpql.cjs",
  "module": "dist/jquery-bpql.esm.js",
  "browser": "dist/jquery-bpql.umd.js",
  "unpkg": "dist/jquery-bpql.umd.min.js",
  "jsdelivr": "dist/jquery-bpql.umd.min.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/jquery-bpql.esm.js",
      "require": "./dist/jquery-bpql.cjs",
      "default": "./dist/jquery-bpql.umd.js"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "./src/index.js",
    "*.scss"
  ],
  "files": [
    "dist",
    "src",
    "types",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "eslint src rollup.config.mjs eslint.config.mjs test",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepare": "npm run build",
    "prepack": "npm run build"
  },
  "keywords": [
    "bpql",
    "bipbop",
    "jquery",
    "jquery-plugin",
    "query-language",
    "sql",
    "xml",
    "websocket",
    "api",
    "irql"
  ],
  "author": "BIPBOP (https://www.bipbop.com.br)",
  "contributors": [
    "iCheques (https://github.com/icheques)"
  ],
  "license": "MIT",
  "homepage": "https://github.com/icheques/jquery-bpql#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/icheques/jquery-bpql.git"
  },
  "bugs": {
    "url": "https://github.com/icheques/jquery-bpql/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "jquery": ">=3.0.0 <5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "jquery": "^4.0.0",
    "jsdom": "^26.0.0",
    "rollup": "^4.28.1",
    "sass": "^1.83.0",
    "typescript": "^5.7.2"
  }
}
