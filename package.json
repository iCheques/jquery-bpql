{
  "name": "@credithub/jquery-bpql",
  "version": "2.1.0",
  "description": "Tiny, typed jQuery 4 plugin for talking to BPQL — the SQL-flavored query language created by BIPBOP and used by CreditHub.",
  "type": "module",
  "main": "dist/jquery-bpql.cjs",
  "module": "dist/jquery-bpql.esm.js",
  "browser": "dist/jquery-bpql.umd.js",
  "unpkg": "dist/jquery-bpql.umd.min.js",
  "jsdelivr": "dist/jquery-bpql.umd.min.js",
  "types": "dist/jquery-bpql.d.ts",
  "exports": {
    ".": {
      "types": "./dist/jquery-bpql.d.ts",
      "import": "./dist/jquery-bpql.esm.js",
      "require": "./dist/jquery-bpql.cjs",
      "default": "./dist/jquery-bpql.umd.js"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "./src/index.ts",
    "*.scss"
  ],
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepare": "npm run build",
    "prepack": "npm run build"
  },
  "keywords": [
    "bpql",
    "bipbop",
    "credithub",
    "jquery",
    "jquery-plugin",
    "typescript",
    "query-language",
    "sql",
    "xml",
    "websocket",
    "api",
    "irql"
  ],
  "author": "CreditHub (https://credithub.com.br)",
  "contributors": [
    "iCheques (https://github.com/icheques)",
    "BIPBOP (https://www.bipbop.com.br)"
  ],
  "license": "MIT",
  "homepage": "https://github.com/icheques/jquery-bpql#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/icheques/jquery-bpql.git"
  },
  "bugs": {
    "url": "https://github.com/icheques/jquery-bpql/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@types/jquery": "*",
    "jquery": ">=3.0.0 <5.0.0"
  },
  "peerDependenciesMeta": {
    "@types/jquery": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/jquery": "^3.5.32",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "jquery": "^4.0.0",
    "jsdom": "^26.0.0",
    "rollup": "^4.28.1",
    "rollup-plugin-dts": "^6.1.1",
    "sass": "^1.83.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  }
}
